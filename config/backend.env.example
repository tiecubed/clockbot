# Backend Environment Configuration
# Copy to backend/.env and fill in values

# Database
DATABASE_URL=sqlite:///./data/timetracker.db

# Security - Generate a strong random token
SHARED_TOKEN=your_secure_random_token_here_change_in_production

# Health Check (90 seconds as per requirements)
HEALTH_THRESHOLD_SECONDS=90

# Screenshot Processing
SCREENSHOT_DIR=./screenshots
SCREENSHOT_MAX_WIDTH=1920
SCREENSHOT_QUALITY=70

# Discord OAuth (for agent authentication flow)
DISCORD_CLIENT_ID=your_discord_app_id
DISCORD_CLIENT_SECRET=your_discord_app_secret

# Server
HOST=0.0.0.0
PORT=8000
